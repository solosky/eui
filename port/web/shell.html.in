<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>@EXAMPLE_TITLE@ — EUI</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{display:flex;flex-direction:column;align-items:center;
       font-family:-apple-system,BlinkMacSystemFont,sans-serif;
       background:#f5f5f5;min-height:100vh;padding:16px}
  h1{font-size:18px;margin-bottom:12px;color:#333}
  canvas{display:block;image-rendering:pixelated;
         border:1px solid #ccc;background:#fff;margin-bottom:16px}
  #fps{font-size:12px;color:#999;margin-bottom:8px;display:none}
  #zoom{font-size:12px;color:#666;margin-bottom:8px;display:flex;align-items:center;gap:4px}
  #zoom span{color:#999;min-width:28px;text-align:center}
  .zoom-btn{width:24px;height:24px;font-size:14px;line-height:22px;text-align:center;
            background:#e0e0e0;border:1px solid #bbb;border-radius:4px;cursor:pointer;
            touch-action:manipulation;user-select:none;-webkit-user-select:none}
  .zoom-btn:active{background:#ccc}
  #dpad{display:grid;gap:4px;justify-items:center;
         grid-template-areas:". up ." "left ok right" ". down ." "back back back"}
  .dpad-btn{width:48px;height:48px;font-size:20px;
            background:#e0e0e0;border:1px solid #bbb;border-radius:6px;
            touch-action:manipulation;user-select:none;-webkit-user-select:none}
  .dpad-btn:active{background:#ccc}
  #btn-up{grid-area:up}#btn-down{grid-area:down}
  #btn-left{grid-area:left}#btn-right{grid-area:right}
  #btn-ok{grid-area:ok}#btn-back{grid-area:back;width:auto;padding:0 16px}
  @media(hover:hover)and(pointer:fine){#dpad{display:none}}
</style>
</head>
<body>
<h1>@EXAMPLE_TITLE@</h1>
<div id="fps">FPS: --</div>
<div id="zoom"><button class="zoom-btn" onclick="zoomOut()">−</button><span>4x</span><button class="zoom-btn" onclick="zoomIn()">+</button></div>
<canvas id="eui-canvas"></canvas>
<div id="dpad">
  <button id="btn-up"    class="dpad-btn">&#9650;</button>
  <button id="btn-down"  class="dpad-btn">&#9660;</button>
  <button id="btn-left"  class="dpad-btn">&#9664;</button>
  <button id="btn-right" class="dpad-btn">&#9654;</button>
  <button id="btn-ok"    class="dpad-btn">OK</button>
  <button id="btn-back"  class="dpad-btn">&#9664; BACK</button>
</div>
<script src="@EXAMPLE_JS@"></script>
<script src="../shell.js"></script>
</body>
</html>
